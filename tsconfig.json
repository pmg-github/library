{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "jsx": "preserve",
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": false
  },
  "include": [
    "components/**/*",
    "composables/**/*",
    "plugins/**/*",
    "tiptap/**/*",
    "stories/**/*",
    "shims-vue.d.ts",
    "nuxt.config.ts"
  ],
  "exclude": [
    "**/*.stories.ts",
    "**/*.stories.d.ts",
    "**/*.stories.js",
    "auto-imports.d.ts",
    "components.d.ts",
    "dist"
  ]
}
