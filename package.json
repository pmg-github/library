{
  "name": "pmg-library",
  "private": true,
  "version": "0.0.1",
  "description": "A Vue 3 component library integration for Nuxt projects",
  "keywords": [
    "vue",
    "nuxt",
    "components",
    "vee-validate"
  ],
  "type": "module",
  "module": "./dist/pmg-library.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/pmg-library.js"
    },
    "./gallery": {
      "types": "./src/extensions/Gallery.ts",
      "import": "./src/extensions/Gallery.ts"
    },
    "./nuxt.config": "./nuxt.config.ts"
  },
  "files": [
    "dist",
    "src",
    "nuxt.config.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "reka-ui": "^2.4.1"
  },
  "peerDependencies": {
    "@headlessui/vue": "^1.7.0",
    "@tiptap/core": "^2.0.0",
    "@tiptap/vue-3": "^2.0.0",
    "nuxt": "^3.0.0 || ^4.0.0",
    "vee-validate": "^4.15.0",
    "vue": "^3.5.13",
    "yup": "^1.6.1"
  },
  "peerDependenciesMeta": {
    "@headlessui/vue": {
      "optional": true
    },
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/vue-3": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "vee-validate": {
      "optional": true
    },
    "yup": {
      "optional": true
    }
  },
  "devDependencies": {
    "@headlessui/vue": "^1.7.23",
    "@storybook/addon-a11y": "^9.0.8",
    "@storybook/addon-docs": "^9.0.8",
    "@storybook/vue3-vite": "^9.0.8",
    "@tailwindcss/postcss": "^4.1.10",
    "@tiptap/core": "^3.27.3",
    "@tiptap/vue-3": "^3.27.3",
    "@types/node": "^24.0.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.5",
    "storybook": "^9.0.8",
    "tailwindcss": "^4.1.10",
    "typescript": "~5.8.3",
    "vee-validate": "^4.15.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^2.2.8",
    "yup": "^1.6.1"
  }
}
